<t tx="swot.20260313114540.261">
**场景**：将项目中的“添加”、“删除”操作，结合 `async/await` 写得更规范。

**步骤 1：封装请求模块**
为了代码复用，我们封装一个 `request.js`。

```javascript
// 基础地址
const BASE_URL = 'http://localhost:3000'; // 假设我们用了 JSON Server

async function request(url, options = {}) {
    try {
        let res = await fetch(BASE_URL + url, options);
        return await res.json();
    } catch (error) {
        console.error("请求出错：", error);
        return null;
    }
}
```

**步骤 2：重构业务逻辑**
```javascript
// 获取商品
async function getGoods() {
    let data = await request('/goods');
    if (data) {
        renderGoods(data);
    }
}

// 删除商品
async function deleteGoods(id) {
    // fetch 删除请求需要 method: 'DELETE'
    await request(`/goods/${id}`, { method: 'DELETE' });
    // 删除成功后，重新获取列表
    getGoods();
}

// 添加商品 {
    let newGoods = { name: "新书", price: 50 };
    // fetch 提交数据需要 method, headers, body
    await request('/goods', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(newGoods)
    });
    getGoods();
}
```

---

