<t tx="swot.20260313114540.323">```javascript
$(function() {
    $('#accordion').on('click', '.header', function() {
        // 1. 获取当前点击项的内容区
        let $content = $(this).next('.content');
        
        // 2. 收起其他所有兄弟项的内容
        // 逻辑：找父级 -&gt; 找兄弟 -&gt; 找内容 -&gt; 滑动收起
        $(this).parent().siblings().find('.content').slideUp();
        
        // 3. 切换箭头方向 (其他兄弟箭头复原)
        $(this).parent().siblings().find('.icon').removeClass('rotate-180');
        $(this).find('.icon').toggleClass('rotate-180');

        // 4. 当前内容区滑动切换
        $content.slideToggle(300); // 300ms 速度
    });
});
```

