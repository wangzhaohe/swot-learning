<t tx="swot.20251030081409.1">@doc
[source,java]
----
@c
@language java
class Factory {

    // 定义静态方法
    public static Product createProduct(String type) {
        switch (type) {
            case "A":
                return new ProductA();
            case "B":
                return new ProductB();
            default:
                throw new IllegalArgumentException(
                          "Unknown product type:" + type);
        }
    }
}
@doc
