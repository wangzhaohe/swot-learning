<t tx="swot.20260313114540.196">
**场景**：完善 Ch 9 的发布商品功能，加入严格的验证逻辑。

**步骤 1：HTML 表单结构**
```html
&lt;form id="addForm"&gt;
    商品名：&lt;input type="text" id="g-name"&gt; &lt;span class="msg"&gt;&lt;/span&gt;&lt;br&gt;
    价格：&lt;input type="text" id="g-price"&gt; &lt;span class="msg"&gt;&lt;/span&gt;&lt;br&gt;
    手机号：&lt;input type="text" id="g-phone"&gt; &lt;span class="msg"&gt;&lt;/span&gt;&lt;br&gt;
    &lt;button type="submit"&gt;发布&lt;/button&gt;
&lt;/form&gt;
```

**步骤 2：JS 验证逻辑**
```javascript
let form = document.querySelector('#addForm');
let gName = document.querySelector('#g-name');
let gPrice = document.querySelector('#g-price');
let gPhone = document.querySelector('#g-phone');

// 表单提交事件
form.onsubmit = function(e) {
    // 1. 阻止默认提交行为
    e.preventDefault();

    // 2. 获取值
    let nameVal = gName.value.trim();
    let priceVal = gPrice.value.trim();
    let phoneVal = gPhone.value.trim();

    // 3. 验证逻辑
    if (nameVal === '') {
        alert('商品名不能为空');
        return; // 终止函数
    }

    // 价格必须是数字且大于0
    // isNaN() 判断是否为非数字
    if (isNaN(priceVal) || priceVal &lt;= 0) {
        alert('请输入正确的价格');
        return;
    }

    // 手机号正则
    let phoneReg = /^1[3-9]\d{9}$/;
    if (!phoneReg.test(phoneVal)) {
        alert('手机号格式错误');
        return;
    }

    // 4. 全部通过，执行添加逻辑
    alert('验证通过，发布成功！');
    // ... 调用之前的添加函数 ...
};
```

