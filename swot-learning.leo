<t tx="swot.20260313114540.177">**需求**：输入内容，点击发布，添加到列表；点击列表项，删除该条留言。

```html
&lt;textarea id="msg"&gt;&lt;/textarea&gt;
&lt;button id="publish"&gt;发布&lt;/button&gt;
&lt;ul id="list"&gt;&lt;/ul&gt;

&lt;script&gt;
    let msg = document.querySelector('#msg');
    let publish = document.querySelector('#publish');
    let list = document.querySelector('#list');

    // 1. 发布功能
    publish.onclick = function() {
        let content = msg.value;
        if (content.trim() === '') {
            alert('内容不能为空！');
            return;
        }

        // 创建li
        let li = document.createElement('li');
        li.innerText = content;

        // 添加到ul的最前面 (insertBefore)
        list.insertBefore(li, list.children[0]);

        // 清空文本框
        msg.value = '';
    };

    // 2. 删除功能 (点击留言删除)
    // 这里给ul注册点击事件，利用事件源判断
    list.onclick = function(e) {
        // e.target 返回的是你点击的那个元素
        if (e.target.tagName === 'LI') {
            list.removeChild(e.target);
        }
    };
&lt;/script&gt;
```

---

</t>
<t tx="swot.20260313114540.178">
**场景**：这是前端开发最核心的环节：**数据驱动视图**。我们要把内存里的数组数据，变成网页上的HTML结构。

**步骤 1：准备容器**
HTML中只保留一个空壳：
```html
&lt;div class="goods-list" id="goodsBox"&gt;
    &lt;!-- 这里原本是空的 --&gt;
&lt;/div&gt;
```

**步骤 2：封装渲染函数**
核心思想：遍历数组 -&gt; 拼接字符串 -&gt; innerHTML 填入。

```javascript
// 模拟数据
let goodsData = [
    { id: 1, name: '高等数学', price: 15 },
    { id: 2, name: '二手吉他', price: 200 }
];

let goodsBox = document.querySelector('#goodsBox');

function renderGoods() {
    // 清空容器
    goodsBox.innerHTML = '';

    // 遍历数组
    goodsData.forEach(item =&gt; {
        // 创建 div
        let div = document.createElement('div');
        div.className = 'goods-item';
        
        // 填充内容
        div.innerHTML = `
            &lt;h4&gt;${item.name}&lt;/h4&gt;
            &lt;p&gt;价格：￥${item.price}&lt;/p&gt;
            &lt;button data-id="${item.id}"&gt;删除&lt;/button&gt;
        `;

        // 添加到容器
        goodsBox.appendChild(div);
    });
}

// 页面加载先渲染一次
renderGoods();
```

**步骤 3：实现“发布商品”功能**
```javascript
let addBtn = document.querySelector('#addBtn'); // 假设HTML里有一个添加按钮

addBtn.onclick = function() {
    // 1. 获取用户输入(假设有输入框)
    // ...

    // 2. 模拟新增数据
    let newGoods = {
        id: Date.now(), // 时间戳做ID
        name: '新书' + Math.random(),
        price: 50
    };

    // 3. 数据推入数组
    goodsData.push(newGoods);

    // 4. 重新渲染页面
    renderGoods();
};
```

---

</t>
