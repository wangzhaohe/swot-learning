<t tx="swot.20260310165817.1">public void registerCard(BaseDoorCard card) {

    whitelist.add(card); // 添加到列表
    whitelistMap.put(card.getSerialNumber(), card); // 建立键值映射 &lt;2&gt;

    System.out.println("系统：已授权 " + card.getOwnerName() +
