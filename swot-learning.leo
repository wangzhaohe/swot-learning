        Industries_list ..&gt; news
        Solutions_list ..&gt; news
        Customization_list ..&gt; news
        CompanyInformation_list .up.&gt; news
        NewsandEvents_list .up.&gt; news
        Support_list .up.&gt; news
    }
}
@enduml
....
</t>
