@language javascript
let oldArr = ['a', 'b', 'a', 'c', 'b'];
let newArr = [];

for (let i = 0; i &lt; oldArr.length; i++) {
    if (newArr.indexOf(oldArr[i]) === -1) {
        newArr.push(oldArr[i]);
