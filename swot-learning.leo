<t tx="swot.20260314151306.1" annotate="7d71002858080000007072696f7269747971014b16580a000000707269736574646174657102580a000000323032362d30332d31357103752e" icons="">@language javascript
/**
 * 函数：生成测试商品数据
 * 参数：count (生成多少个)
 */
function generateGoods(count) {
    // 清空原数组
    goodsList = [];

    // 商品名称模板
    const names = ["高等数学", "大学英语", "计算机网络", "二手自行车", "台灯", "风扇", "U盘"];

    for (let i = 1; i &lt;= count; i++) {
        // 生成一个随机商品对象
        let goods = {
            id: i,
            name: names[Math.floor(Math.random() * names.length)] + " (第" + i + "件)",
            finalPrice: Math.floor(Math.random() * 100) + 10, // 10-110之间的随机价格
            date: "2026-10-" + (Math.floor(Math.random() * 28) + 1), // 随机日期
            isSold: Math.random() &gt; 0.8 // 随机生成是否已售出 (80%未售，20%已售)
        };
        // 把商品推入仓库
        goodsList.push(goods);
    }
    console.log(`成功生成 ${count} 条商品数据！`);
}
</t>
