        ? goodsList[goodsList.length - 1].id + 1
        : 1;

    let newGoods = {
        id: id,
        name: name,
        price: price,
        category: category,
        pubTime: "2026-03-15 10:16:40",
    };

    goodsList.push(newGoods);

    console.log(`商品【${name}】添加成功！`);
},
</t>
