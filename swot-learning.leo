<t tx="swot.20260313114540.214">
**核心**：利用定时器，极短时间内修改元素的位置，利用人眼的视觉暂留形成动画。

**步骤**：

1.  获取元素当前位置。
2.  修改位置（+1 或 -1）。
3.  赋值回去。
4.  使用定时器重复执行。

**演示：匀速动画**
```javascript
let box = document.querySelector('.box');

function move() {
    let timer = setInterval(function() {
        // 获取当前位置 (parseInt 去掉px单位)
        let left = parseInt(window.getComputedStyle(box).left);
        
        if (left &gt;= 500) {
            clearInterval(timer); // 到达终点停止
        } else {
            box.style.left = left + 5 + 'px'; // 每次走5px
        }
    }, 30); // 30毫秒刷新一次，约每秒33帧
}
```

---

</t>
<t tx="swot.20260313114540.215">
为了方便使用，我们把动画封装成函数。
`animate(obj, target, speed)`

```javascript
function animate(obj, target) {
    clearInterval(obj.timer); // 先清除以前的定时器，防止加速
    obj.timer = setInterval(function() {
        let left = parseInt(window.getComputedStyle(obj).left);
        if (left &gt;= target) {
            clearInterval(obj.timer);
        } else {
            obj.style.left = left + 5 + 'px';
        }
    }, 30);
}
```

