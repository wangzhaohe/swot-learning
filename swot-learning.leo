示例 4：Storage 事件跨标签通信

```javascript
/**
 * 跨标签页通信通道（BroadcastChannel的降级方案）
 */
class StorageChannel {
  constructor(channelName) {
    this.channel = channelName;
    this.listeners = new Map();
    
    // 监听storage事件（BOM特性）
    window.addEventListener('storage', (e) =&gt; {
      if (e.key === this.channel &amp;&amp; e.newValue) {
        try {
          const message = JSON.parse(e.newValue);
          this.handleMessage(message);
        } catch (err) {
          console.error('消息解析失败:', err);
        }
      }
    });
  }

  /**
   * 发送消息到其他标签页
   */
  postMessage(type, payload) {
    const message = {
      type,
      payload,
      timestamp: Date.now(),
      sender: Math.random().toString(36).substr(2, 9) // 简单ID
    };
    
    // 使用localStorage触发storage事件
    // 立即删除，避免污染存储空间
    localStorage.setItem(this.channel, JSON.stringify(message));
    setTimeout(() =&gt; localStorage.removeItem(this.channel), 100);
  }

  /**
   * 订阅消息
   */
  on(type, handler) {
    if (!this.listeners.has(type)) {
      this.listeners.set(type, new Set());
    }
    this.listeners.get(type).add(handler);
    
    // 返回取消订阅
    return () =&gt; this.listeners.get(type)?.delete(handler);
  }

  handleMessage(message) {
    const handlers = this.listeners.get(message.type);
    if (handlers) {
      handlers.forEach(h =&gt; h(message.payload, message));
    }
  }
}

// 使用：实现多标签页登录状态同步
const authChannel = new StorageChannel('app_auth');

// 标签页A：监听登出
authChannel.on('logout', () =&gt; {
  window.location.href = '/login';
  alert('您已在其他标签页退出登录');
});

// 标签页B：执行登出
document.getElementById('logout').addEventListener('click', () =&gt; {
  // 清除登录状态
  localStorage.removeItem('token');
  // 通知其他标签页
  authChannel.postMessage('logout', { reason: 'user_action' });
});
```

