        StudentCard studentCard = new StudentCard("S-2024-001", "小明");
        AdminCard adminCard = new AdminCard("A-007", "张老师");

        CanteenReader canteen = new CanteenReader();

        // 1. 学生卡实现了 Payable，可以打饭
        canteen.processPayment(studentCard, 15.0);

