    @Override
    public boolean validate() throws DoorException {
        boolean isValid = super.validate();
        if (isValid) {
            showAccessScope();
        }
        return isValid;
    }

    @Override
    public void showAccessScope() {
        System.out.println("【权限范围】管理员卡：开启全校所有通道，含机房与档案室。");
    }
}
</t>
