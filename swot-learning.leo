<t tx="swot.20260309094910.105">@language xml
&lt;mirrors&gt;
  &lt;!-- &lt;mirror&gt; --&gt;
      &lt;!-- &lt;id&gt;alimaven&lt;/id&gt; --&gt;
      &lt;!-- &lt;mirrorOf&gt;central&lt;/mirrorOf&gt; --&gt;
      &lt;!-- &lt;name&gt;阿里云公共仓库&lt;/name&gt; --&gt;
      &lt;!-- &lt;url&gt;https://maven.aliyun.com/repository/public&lt;/url&gt; --&gt;
  &lt;!-- &lt;/mirror&gt; --&gt;
  &lt;mirror&gt;
      &lt;!-- 因为 maven-public 是 Group，所以只配置它就可以了 --&gt;
      &lt;id&gt;maven-public&lt;/id&gt;
      &lt;!-- &lt;mirrorOf&gt;*&lt;/mirrorOf&gt; --&gt;
      &lt;!-- *,!central 就是给官方仓库开绿灯，让官方仓库的插件请求绕开私服，避免找不到插件而失败； --&gt;
      &lt;!-- 同时保留私服对其它仓库的代理功能，兼顾速度与可用性。 --&gt;
      &lt;mirrorOf&gt;*,!central&lt;/mirrorOf&gt;
      &lt;url&gt;http://localhost:8081/repository/maven-public/&lt;/url&gt;
  &lt;/mirror&gt;
&lt;/mirrors&gt;
</t>
<t tx="swot.20260309094910.106">@language xml
&lt;profiles&gt;
  &lt;profile&gt;
      &lt;id&gt;allow-snapshots&lt;/id&gt;
      &lt;activation&gt;
          &lt;activeByDefault&gt;true&lt;/activeByDefault&gt;
      &lt;/activation&gt;
      &lt;repositories&gt;
          &lt;repository&gt;
              &lt;id&gt;maven-public&lt;/id&gt;
              &lt;url&gt;http://localhost:8081/repository/maven-public/&lt;/url&gt;
              &lt;releases&gt;
                  &lt;enabled&gt;true&lt;/enabled&gt;
              &lt;/releases&gt;
              &lt;snapshots&gt;
                  &lt;enabled&gt;true&lt;/enabled&gt;
              &lt;/snapshots&gt;
          &lt;/repository&gt;
      &lt;/repositories&gt;
  &lt;/profile&gt;
&lt;/profiles&gt;

&lt;!-- 这个配置就是告诉 Maven： --&gt;

&lt;!-- “默认启用一个叫 allow-snapshots 的 profile，把我的 Nexus 私服 maven-public 当作依赖仓库，并允许从里面下载 正式版和快照版 的依赖。” --&gt;
</t>
