<t tx="swot.20260313114540.325">点击加减按钮修改数量，自动计算小计和总价。

</t>
<t tx="swot.20260313114540.326">```html
&lt;div class="max-w-2xl mx-auto mt-10 bg-white shadow-lg rounded-lg overflow-hidden"&gt;
    &lt;!-- 表头 --&gt;
    &lt;div class="grid grid-cols-5 gap-4 bg-gray-100 p-4 font-bold text-gray-700 text-center"&gt;
        &lt;div class="col-span-2"&gt;商品信息&lt;/div&gt;
        &lt;div&gt;单价&lt;/div&gt;
        &lt;div&gt;数量&lt;/div&gt;
        &lt;div&gt;小计&lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- 商品列表 --&gt;
    &lt;div id="cartList"&gt;
        &lt;!-- 商品行 1 --&gt;
        &lt;div class="item grid grid-cols-5 gap-4 p-4 border-b items-center text-center"&gt;
            &lt;div class="col-span-2 flex items-center"&gt;
                &lt;img src="https://via.placeholder.com/80" class="w-20 h-20 object-cover rounded mr-4"&gt;
                &lt;span class="font-medium"&gt;JavaScript 高级编程&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="price text-gray-500"&gt;￥&lt;span&gt;59.00&lt;/span&gt;&lt;/div&gt;
            &lt;div class="flex justify-center items-center space-x-2"&gt;
                &lt;button class="minus w-8 h-8 bg-gray-200 rounded hover:bg-gray-300 font-bold"&gt;-&lt;/button&gt;
                &lt;input type="text" value="1" class="w-12 border text-center h-8 rounded quantity" readonly&gt;
                &lt;button class="plus w-8 h-8 bg-blue-500 text-white rounded hover:bg-blue-600 font-bold"&gt;+&lt;/button&gt;
            &lt;/div&gt;
            &lt;div class="sub-total text-red-500 font-bold"&gt;￥&lt;span&gt;59.00&lt;/span&gt;&lt;/div&gt;
        &lt;/div&gt;

        &lt;!-- 商品行 2 (复制即可) --&gt;
        &lt;div class="item grid grid-cols-5 gap-4 p-4 border-b items-center text-center"&gt;
            &lt;div class="col-span-2 flex items-center"&gt;
                &lt;img src="https://via.placeholder.com/80" class="w-20 h-20 object-cover rounded mr-4"&gt;
                &lt;span class="font-medium"&gt;Vue.js 实战&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="price text-gray-500"&gt;￥&lt;span&gt;45.00&lt;/span&gt;&lt;/div&gt;
            &lt;div class="flex justify-center items-center space-x-2"&gt;
                &lt;button class="minus w-8 h-8 bg-gray-200 rounded hover:bg-gray-300 font-bold"&gt;-&lt;/button&gt;
                &lt;input type="text" value="1" class="w-12 border text-center h-8 rounded quantity" readonly&gt;
                &lt;button class="plus w-8 h-8 bg-blue-500 text-white rounded hover:bg-blue-600 font-bold"&gt;+&lt;/button&gt;
            &lt;/div&gt;
            &lt;div class="sub-total text-red-500 font-bold"&gt;￥&lt;span&gt;45.00&lt;/span&gt;&lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- 结算栏 --&gt;
    &lt;div class="p-4 bg-gray-50 flex justify-end items-center space-x-4"&gt;
        &lt;span&gt;总计：&lt;span id="totalPrice" class="text-2xl text-red-500 font-bold"&gt;￥104.00&lt;/span&gt;&lt;/span&gt;
        &lt;button class="bg-red-500 text-white px-6 py-2 rounded hover:bg-red-600 transition"&gt;去结算&lt;/button&gt;
    &lt;/div&gt;
&lt;/div&gt;
```

</t>
<t tx="swot.20260313114540.327">```javascript
$(function() {
    // 封装计算总价的函数
    function calculateTotal() {
        let total = 0;
        // 遍历每一个商品行
        $('.item').each(function() {
            // 获取单价和数量
            // 注意：.text() 获取的是文本，需要转数字
            let price = parseFloat($(this).find('.price span').text());
            let num = parseInt($(this).find('.quantity').val());
            
            // 计算小计
            let subTotal = price * num;
            
            // 设置小计 (保留两位小数)
            $(this).find('.sub-total span').text(subTotal.toFixed(2));
            
            // 累加总价
            total += subTotal;
        });
        
        // 设置总价
        $('#totalPrice').text('￥' + total.toFixed(2));
    }

    // 1. 加号点击事件
    $('#cartList').on('click', '.plus', function() {
        // 获取当前输入框对象
        let $input = $(this).siblings('.quantity');
        let num = parseInt($input.val());
        $input.val(num + 1);
        
        // 重新计算
        calculateTotal();
    });

    // 2. 减号点击事件
    $('#cartList').on('click', '.minus', function() {
        let $input = $(this).siblings('.quantity');
        let num = parseInt($input.val());
        
        if (num &gt; 1) {
            $input.val(num - 1);
            calculateTotal();
        } else {
            alert("数量不能少于1");
        }
    });
    
    // 初始化计算一次
    calculateTotal();
});
```

---

</t>
<t tx="swot.20260313114540.328">
**1. 关于 jQuery 选择器的技巧**：
*   在购物车案例中，使用了 `$(this).siblings('.quantity')`，这是非常典型的“相对查找”思维。不要在循环里给每个 input 加 ID，而是通过按钮的位置去找旁边的元素，这在动态生成的列表中尤为重要。

**2. 关于 Tailwind 的响应式**：
*   在手风琴案例中，你可以尝试在小屏幕下改变布局。例如给容器加上 `md:w-1/2 w-full`，这能让学生直观感受响应式开发的便捷。

**3. 关于数据类型**：
*   购物车案例中必须强调 `parseFloat` 和 `parseInt`。JS 从 HTML 取出来的永远是字符串，直接相加会变成字符串拼接（如 "59" + 1 = "591"），这是初学者最容易犯的错。



</t>
<t tx="swot.20260313114540.329">
**场景**：我们要为“易校园”做一个后台管理界面，用于查看所有发布的商品。要求：布局快（Tailwind）、逻辑快。


```html
&lt;!doctype html&gt;
&lt;html&gt;
&lt;head&gt;
  &lt;meta charset="UTF-8"&gt;
  &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
  &lt;title&gt;易校园管理系统&lt;/title&gt;
  &lt;script src="https://code.jquery.com/jquery-3.6.0.min.js"&gt;&lt;/script&gt;
  &lt;script src="https://cdn.tailwindcss.com"&gt;&lt;/script&gt;
  &lt;style&gt;
    .sort-icon { font-size: 12px; margin-left: 4px; color: #999; }
    .active-sort { color: #3b82f6; }
  &lt;/style&gt;
&lt;/head&gt;
&lt;body class="bg-gray-100 font-sans"&gt;

    &lt;!-- 顶部导航 --&gt;
    &lt;nav class="bg-blue-600 text-white p-4 shadow-md flex justify-between items-center"&gt;
        &lt;div class="text-xl font-bold"&gt;易校园管理系统&lt;/div&gt;
        &lt;div&gt;
            &lt;span class="mr-4"&gt;管理员&lt;/span&gt;
            &lt;button class="bg-blue-700 px-3 py-1 rounded hover:bg-blue-800"&gt;退出&lt;/button&gt;
        &lt;/div&gt;
    &lt;/nav&gt;

    &lt;div class="container mx-auto mt-6 p-4"&gt;
        &lt;div class="bg-white rounded shadow p-6"&gt;
            &lt;!-- 工具栏 --&gt;
            &lt;div class="flex justify-between mb-4"&gt;
                &lt;input type="text" id="search" placeholder="搜索商品..." 
                       class="border px-3 py-2 rounded focus:ring focus:ring-blue-300 outline-none w-64"&gt;
                &lt;button id="addBtn" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600"&gt;新增商品&lt;/button&gt;
            &lt;/div&gt;
            
            &lt;!-- 表格 --&gt;
            &lt;table class="w-full text-left border-collapse"&gt;
                &lt;thead class="bg-gray-50"&gt;
                    &lt;tr&gt;
                        &lt;th class="p-3 border cursor-pointer hover:bg-gray-100" data-key="id"&gt;ID &lt;span class="sort-icon"&gt;↕&lt;/span&gt;&lt;/th&gt;
                        &lt;th class="p-3 border cursor-pointer hover:bg-gray-100" data-key="name"&gt;商品名称 &lt;span class="sort-icon"&gt;↕&lt;/span&gt;&lt;/th&gt;
                        &lt;th class="p-3 border cursor-pointer hover:bg-gray-100" data-key="price"&gt;价格 &lt;span class="sort-icon"&gt;↕&lt;/span&gt;&lt;/th&gt;
                        &lt;th class="p-3 border cursor-pointer hover:bg-gray-100" data-key="category"&gt;分类 &lt;span class="sort-icon"&gt;↕&lt;/span&gt;&lt;/th&gt;
                        &lt;th class="p-3 border"&gt;操作&lt;/th&gt;
                    &lt;/tr&gt;
                &lt;/thead&gt;
                &lt;tbody id="goodsTable"&gt;&lt;/tbody&gt;
            &lt;/table&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- 自定义确认弹窗 (替代原生 confirm) --&gt;
    &lt;div id="confirmModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex justify-center items-center z-[100]"&gt;
        &lt;div class="bg-white rounded-lg shadow-2xl w-full max-w-sm mx-4 p-6 text-center"&gt;
            &lt;div class="text-red-500 text-5xl mb-4"&gt;⚠️&lt;/div&gt;
            &lt;h3 class="text-lg font-bold mb-2 text-gray-800"&gt;操作提示&lt;/h3&gt;
            &lt;p id="confirmMsg" class="text-gray-600 mb-6"&gt;确定要执行此操作吗？&lt;/p&gt;
            &lt;div class="flex justify-center space-x-4"&gt;
                &lt;button id="confirmCancel" class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 w-24"&gt;取消&lt;/button&gt;
                &lt;button id="confirmOk" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 w-24"&gt;确定&lt;/button&gt;
            &lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- 新增/编辑 模态框 --&gt;
    &lt;div id="formModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex justify-center items-center z-50"&gt;
        &lt;div class="bg-white rounded-lg shadow-2xl w-full max-w-md mx-4 p-6"&gt;
            &lt;h3 id="modalTitle" class="text-xl font-bold mb-4 text-gray-800"&gt;新增商品&lt;/h3&gt;
            &lt;form id="dataForm"&gt;
                &lt;input type="hidden" id="editId"&gt;
                &lt;div class="mb-4"&gt;
                    &lt;label class="block text-gray-700 text-sm font-bold mb-2"&gt;商品名称&lt;/label&gt;
                    &lt;input type="text" id="inputName" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"&gt;
                &lt;/div&gt;
                &lt;div class="mb-4"&gt;
                    &lt;label class="block text-gray-700 text-sm font-bold mb-2"&gt;价格&lt;/label&gt;
                    &lt;input type="number" id="inputPrice" required step="0.01" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"&gt;
                &lt;/div&gt;
                &lt;div class="mb-6"&gt;
                    &lt;label class="block text-gray-700 text-sm font-bold mb-2"&gt;分类&lt;/label&gt;
                    &lt;select id="inputCategory" class="shadow border rounded w-full py-2 px-3 text-gray-700"&gt;
                        &lt;option value="书籍"&gt;书籍&lt;/option&gt;
                        &lt;option value="乐器"&gt;乐器&lt;/option&gt;
                        &lt;option value="生活"&gt;生活&lt;/option&gt;
                        &lt;option value="数码"&gt;数码&lt;/option&gt;
                    &lt;/select&gt;
                &lt;/div&gt;
                &lt;div class="flex items-center justify-end"&gt;
                    &lt;button type="button" id="cancelBtn" class="mr-2 px-4 py-2 text-gray-600 hover:text-gray-800"&gt;取消&lt;/button&gt;
                    &lt;button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded"&gt;保存&lt;/button&gt;
                &lt;/div&gt;
            &lt;/form&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;script&gt;
        // ==========================================
        // 1. 数据初始化
        // ==========================================
        let goodsData = [
            { id: 1, name: "高等数学", price: 15, category: "书籍" },
            { id: 2, name: "二手吉他", price: 200, category: "乐器" },
            { id: 3, name: "台灯", price: 35, category: "生活" }
        ];

        let sortState = { key: null, order: 'asc' };
        const $formModal = $('#formModal');
        const $form = $('#dataForm');
        const $confirmModal = $('#confirmModal'); // 确认框

        // ==========================================
        // 2. 核心渲染函数
        // ==========================================
        function renderTable(data) {
            let list = data || goodsData;
            $('#goodsTable').empty();
            
            if (list.length === 0) {
                $('#goodsTable').append('&lt;tr&gt;&lt;td colspan="5" class="p-4 text-center text-gray-400"&gt;暂无数据&lt;/td&gt;&lt;/tr&gt;');
                return;
            }

            $.each(list, function(i, item) {
                let tr = `
                    &lt;tr class="hover:bg-gray-50"&gt;
                        &lt;td class="p-3 border"&gt;${item.id}&lt;/td&gt;
                        &lt;td class="p-3 border"&gt;${item.name}&lt;/td&gt;
                        &lt;td class="p-3 border text-red-500 font-bold"&gt;￥${item.price.toFixed(2)}&lt;/td&gt;
                        &lt;td class="p-3 border"&gt;&lt;span class="bg-blue-100 text-blue-700 text-xs px-2 py-1 rounded"&gt;${item.category}&lt;/span&gt;&lt;/td&gt;
                        &lt;td class="p-3 border"&gt;
                            &lt;button class="edit-btn bg-yellow-400 px-2 py-1 rounded text-white text-sm hover:bg-yellow-500" data-id="${item.id}"&gt;编辑&lt;/button&gt;
                            &lt;button class="del-btn bg-red-400 px-2 py-1 rounded text-white text-sm hover:bg-red-500 ml-1" data-id="${item.id}"&gt;删除&lt;/button&gt;
                        &lt;/td&gt;
                    &lt;/tr&gt;
                `;
                $('#goodsTable').append(tr);
            });
        }

        renderTable();

        // ==========================================
        // 3. 自定义确认框逻辑 (替代原生 confirm)
        // ==========================================
        function showConfirm(message, callback) {
            $('#confirmMsg').text(message);
            $confirmModal.removeClass('hidden');

            // 解绑旧事件，防止重复绑定
            $('#confirmOk').off('click').on('click', function() {
                $confirmModal.addClass('hidden');
                if (typeof callback === 'function') {
                    callback(); // 执行回调
                }
            });

            $('#confirmCancel').off('click').on('click', function() {
                $confirmModal.addClass('hidden');
            });
        }

        // ==========================================
        // 4. 删除功能 (使用自定义确认框)
        // ==========================================
        $('#goodsTable').on('click', '.del-btn', function() {
            let id = $(this).data('id');
            
            // 调用自定义确认框
            showConfirm('确定要删除该商品吗？', function() {
                // 用户点击确定后执行
                goodsData = goodsData.filter(item =&gt; item.id !== id);
                $('#search').val('');
                renderTable();
            });
        });

        // ==========================================
        // 5. 搜索功能
        // ==========================================
        $('#search').on('input', function() {
            let keyword = $(this).val().trim().toLowerCase();
            if (!keyword) { renderTable(); return; }
            let filtered = goodsData.filter(item =&gt; 
                item.name.toLowerCase().includes(keyword) || 
                item.category.toLowerCase().includes(keyword)
            );
            renderTable(filtered);
        });

        // ==========================================
        // 6. 排序功能
        // ==========================================
        $('th[data-key]').click(function() {
            let key = $(this).data('key');
            if (sortState.key === key) {
                sortState.order = (sortState.order === 'asc') ? 'desc' : 'asc';
            } else {
                sortState.key = key;
                sortState.order = 'asc';
            }
            $('th[data-key] .sort-icon').text('↕').removeClass('active-sort');
            $(this).find('.sort-icon').text(sortState.order === 'asc' ? '↑' : '↓').addClass('active-sort');

            goodsData.sort((a, b) =&gt; {
                let valA = a[key], valB = b[key];
                if (typeof valA === 'number') return sortState.order === 'asc' ? valA - valB : valB - valA;
                if (typeof valA === 'string') return sortState.order === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
                return 0;
            });
            $('#search').val('');
            renderTable();
        });

        // ==========================================
        // 7. 弹窗控制 (新增 &amp; 编辑)
        // ==========================================
        function openFormModal(isEdit, item = {}) {
            if (isEdit) {
                $('#modalTitle').text('编辑商品');
                $('#editId').val(item.id);
                $('#inputName').val(item.name);
                $('#inputPrice').val(item.price);
                $('#inputCategory').val(item.category);
            } else {
                $('#modalTitle').text('新增商品');
                $('#editId').val('');
                $form[0].reset();
            }
            $formModal.removeClass('hidden');
        }

        function closeFormModal() {
            $formModal.addClass('hidden');
            $form[0].reset();
            $('#editId').val('');
        }

        $('#addBtn').click(function() {
            openFormModal(false);
        });

        $('#goodsTable').on('click', '.edit-btn', function() {
            let id = $(this).data('id');
            let item = goodsData.find(g =&gt; g.id === id);
            if (item) {
                openFormModal(true, item);
            }
        });

        $('#cancelBtn').click(closeFormModal);

        // ==========================================
        // 8. 表单提交
        // ==========================================
        $form.submit(function(e) {
            e.preventDefault();

            let id = $('#editId').val();
            let name = $('#inputName').val().trim();
            let price = parseFloat($('#inputPrice').val());
            let category = $('#inputCategory').val();

            if (!name || isNaN(price)) {
                // 这里也可以用自定义弹窗，为了简单暂用 alert，如果报错同理需替换
                // 暂时简单处理：直接修改文本颜色提示
                if(!name) $('#inputName').css('border-color', 'red'); 
                return;
            }

            if (id) {
                let index = goodsData.findIndex(item =&gt; item.id == id);
                if (index !== -1) {
                    goodsData[index] = { 
                        id: Number(id), 
                        name: name, 
                        price: price, 
                        category: category 
                    };
                }
            } else {
                let maxId = goodsData.length &gt; 0 ? Math.max(...goodsData.map(item =&gt; item.id)) : 0;
                goodsData.push({
                    id: maxId + 1,
                    name: name,
                    price: price,
                    category: category
                });
            }

            closeFormModal();
            $('#search').val('');
            renderTable();
        });

    &lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;
```



---

</t>
<t tx="swot.20260313114540.330">
1.  **概念题**：jQuery 的链式调用是如何实现的？（提示：对象方法返回 `this`）。
