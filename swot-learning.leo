<t tx="swot.20260313114540.203">
</t>
<t tx="swot.20260313114540.204">
| 特性             | LocalStorage                   | SessionStorage               |
| ---------------- | ------------------------------ | ---------------------------- |
| **生命周期**     | 永久存储（除非手动清除）       | 会话级，关闭标签页即清除     |
| **作用域**       | 同源窗口共享（协议+域名+端口） | 同一标签页内，新标签页不共享 |
| **存储容量**     | 约 5-10 MB                     | 约 5-10 MB                   |
| **数据类型**     | 仅支持字符串（需序列化）       | 仅支持字符串（需序列化）     |
| **与服务端通信** | 不自动发送，纯客户端           | 不自动发送，纯客户端         |

</t>
<t tx="swot.20260313114540.205">
```javascript
// Cookie 会随 HTTP 请求发送（影响性能）
// LocalStorage/SessionStorage 纯客户端，不参与网络传输
```

</t>
<t tx="swot.20260313114540.206">
```javascript
// 设置
localStorage.setItem('key', 'value');
localStorage.key = 'value';          // 属性方式（不推荐）
localStorage['key'] = 'value';       // 括号方式

// 获取
localStorage.getItem('key');         // 推荐，key不存在返回null
localStorage.key;                    // 属性方式，可能冲突原型属性

// 删除
localStorage.removeItem('key');      // 删除单个
localStorage.clear();                // 清空所有

// 遍历
localStorage.length;                 // 存储项数量
localStorage.key(index);             // 获取第index个key
```

---

</t>
<t tx="swot.20260313114540.207">
示例 1：基础封装（类型安全版）

```javascript
/**
 * Storage 工具类 - 支持对象序列化与类型安全
 */
class StorageWrapper {
  constructor(storage) {
    this.storage = storage;
  }

  /**
   * 设置值（自动序列化）
   * @param {string} key 
   * @param {any} value 
   * @param {number} expire 过期时间（分钟），仅localStorage支持
   */
  set(key, value, expire = null) {
    try {
      const data = {
        value: value,
        timestamp: Date.now(),
        expire: expire ? Date.now() + expire * 60 * 1000 : null
      };
      this.storage.setItem(key, JSON.stringify(data));
      return true;
    } catch (e) {
      console.error('Storage set error:', e);
      // 容量已满，清理过期数据
      if (e.name === 'QuotaExceededError') {
        this.clearExpired();
        return this.set(key, value, expire);
      }
      return false;
    }
  }

  /**
   * 获取值（自动反序列化+过期检查）
   * @param {string} key 
   * @param {any} defaultValue 
   */
  get(key, defaultValue = null) {
    try {
      const item = this.storage.getItem(key);
      if (!item) return defaultValue;

      const data = JSON.parse(item);
      
      // 检查过期
      if (data.expire &amp;&amp; Date.now() &gt; data.expire) {
        this.storage.removeItem(key);
        return defaultValue;
      }
      
      return data.value;
    } catch (e) {
      console.error('Storage get error:', e);
      return defaultValue;
    }
  }

  /**
   * 删除
   */
  remove(key) {
    this.storage.removeItem(key);
  }

  /**
   * 清空所有
   */
  clear() {
    this.storage.clear();
  }

  /**
   * 清理过期数据（仅localStorage需要）
   */
  clearExpired() {
    const now = Date.now();
    for (let i = 0; i &lt; this.storage.length; i++) {
      const key = this.storage.key(i);
      try {
        const data = JSON.parse(this.storage.getItem(key));
        if (data.expire &amp;&amp; now &gt; data.expire) {
          this.storage.removeItem(key);
        }
      } catch (e) {
        // 非JSON格式，跳过
      }
    }
  }

  /**
   * 获取所有key
   */
  keys() {
    const keys = [];
    for (let i = 0; i &lt; this.storage.length; i++) {
      keys.push(this.storage.key(i));
    }
    return keys;
  }
}

// 导出实例
export const local = new StorageWrapper(localStorage);
export const session = new StorageWrapper(sessionStorage);
```

**使用示例**：
```javascript
import { local, session } from './storage';

// LocalStorage：持久保存用户偏好
local.set('theme', 'dark', 60 * 24 * 7); // 7天过期
local.set('user', { id: 1, name: '张三' });

const theme = local.get('theme', 'light'); // 获取，默认light
const user = local.get('user');

// SessionStorage：临时保存表单数据
session.set('formDraft', { title: '未完成的商品', price: 100 });

// 标签页关闭后重新打开，formDraft不存在
```

---

示例 2：购物车实战（LocalStorage + 跨标签同步）

```javascript
/**
 * 购物车状态管理 - 支持多标签页同步
 */
class ShoppingCart {
  constructor() {
    this.STORAGE_KEY = 'cart_data';
    this.listeners = [];
    
    // 监听其他标签页的修改（BOM特性）
    window.addEventListener('storage', (e) =&gt; {
      if (e.key === this.STORAGE_KEY) {
        console.log('其他标签页修改了购物车:', e.newValue);
        this.notifyListeners();
      }
    });
  }

  /**
   * 获取购物车数据
   */
  getItems() {
    const data = localStorage.getItem(this.STORAGE_KEY);
    return data ? JSON.parse(data) : [];
  }

  /**
   * 添加商品
   */
  addItem(product) {
    const items = this.getItems();
    const existing = items.find(item =&gt; item.id === product.id);
    
    if (existing) {
      existing.quantity += product.quantity || 1;
      existing.updatedAt = Date.now();
    } else {
      items.push({
        ...product,
        quantity: product.quantity || 1,
        addedAt: Date.now()
      });
    }
    
    this.save(items);
    return items;
  }

  /**
   * 更新数量
   */
  updateQuantity(productId, quantity) {
    const items = this.getItems();
    const item = items.find(i =&gt; i.id === productId);
    
    if (item) {
      if (quantity &lt;= 0) {
        return this.removeItem(productId);
      }
      item.quantity = quantity;
      item.updatedAt = Date.now();
      this.save(items);
    }
    return items;
  }

  /**
   * 删除商品
   */
  removeItem(productId) {
    const items = this.getItems().filter(i =&gt; i.id !== productId);
    this.save(items);
    return items;
  }

  /**
   * 清空购物车
   */
  clear() {
    localStorage.removeItem(this.STORAGE_KEY);
    this.notifyListeners();
  }

  /**
   * 计算总价
   */
  getTotal() {
    return this.getItems().reduce((sum, item) =&gt; 
      sum + (item.price * item.quantity), 0
    );
  }

  /**
   * 保存并通知
   */
  save(items) {
    localStorage.setItem(this.STORAGE_KEY, JSON.stringify(items));
    this.notifyListeners();
  }

  /**
   * 订阅变化（用于UI更新）
   */
  subscribe(callback) {
    this.listeners.push(callback);
    // 立即执行一次，获取初始值
    callback(this.getItems());
    
    // 返回取消订阅函数
    return () =&gt; {
      this.listeners = this.listeners.filter(l =&gt; l !== callback);
    };
  }

  notifyListeners() {
    const items = this.getItems();
    this.listeners.forEach(cb =&gt; cb(items));
  }
}

// 使用示例
const cart = new ShoppingCart();

// React/Vue组件中订阅
cart.subscribe((items) =&gt; {
  console.log('购物车更新:', items);
  updateUI(items); // 更新界面
});

// 添加商品
cart.addItem({ id: 1, name: 'iPhone 15', price: 5999, quantity: 1 });

// 在另一个标签页执行同样代码，两个页面会自动同步
```

---

示例 3：SessionStorage 实现页面状态保持

```javascript
/**
 * 表单草稿自动保存（页面刷新/返回恢复）
 */
class FormAutoSave {
  constructor(formId, options = {}) {
    this.formId = formId;
    this.key = `form_draft_${formId}`;
    this.interval = options.interval || 3000; // 3秒自动保存
    this.maxAge = options.maxAge || 30; // 30分钟过期
    
    this.form = document.getElementById(formId);
    this.timer = null;
    
    this.init();
  }

  init() {
    // 页面加载时恢复数据
    this.restore();
    
    // 监听输入变化
    this.form.addEventListener('input', () =&gt; this.debounceSave());
    
    // 页面可见性变化时保存（切回标签页）
    document.addEventListener('visibilitychange', () =&gt; {
      if (document.visibilityState === 'hidden') {
        this.save();
      }
    });
    
    // 提交成功后清除草稿
    this.form.addEventListener('submit', () =&gt; {
      this.clear();
    });
  }

  /**
   * 防抖保存
   */
  debounceSave() {
    clearTimeout(this.timer);
    this.timer = setTimeout(() =&gt; this.save(), this.interval);
  }

  /**
   * 保存表单数据
   */
  save() {
    const formData = new FormData(this.form);
    const data = {
      values: Object.fromEntries(formData),
      timestamp: Date.now(),
      url: window.location.href
    };
    
    sessionStorage.setItem(this.key, JSON.stringify(data));
    console.log('表单草稿已保存');
  }

  /**
   * 恢复表单数据
   */
  restore() {
    const saved = sessionStorage.getItem(this.key);
    if (!saved) return;

    try {
      const data = JSON.parse(saved);
      
      // 检查过期时间
      const age = (Date.now() - data.timestamp) / 1000 / 60; // 分钟
      if (age &gt; this.maxAge) {
        console.log('草稿已过期');
        this.clear();
        return;
      }

      // 检查URL是否匹配（防止不同页面数据混淆）
      if (data.url !== window.location.href) {
        console.log('URL不匹配，跳过恢复');
        return;
      }

      // 填充表单
      Object.entries(data.values).forEach(([name, value]) =&gt; {
        const field = this.form.elements[name];
        if (field) {
          if (field.type === 'checkbox') {
            field.checked = value === 'on' || value === true;
          } else if (field.type === 'radio') {
            const radio = this.form.querySelector(`[name="${name}"][value="${value}"]`);
            if (radio) radio.checked = true;
          } else {
            field.value = value;
          }
        }
      });
      
      console.log('表单草稿已恢复');
    } catch (e) {
      console.error('恢复草稿失败:', e);
    }
  }

  /**
   * 清除草稿
   */
  clear() {
    sessionStorage.removeItem(this.key);
  }
}

// HTML使用
// &lt;form id="productForm"&gt;
//   &lt;input name="title" /&gt;
//   &lt;textarea name="description"&gt;&lt;/textarea&gt;
// &lt;/form&gt;

// JS初始化
const autoSave = new FormAutoSave('productForm', {
  interval: 2000,  // 2秒保存一次
  maxAge: 60       // 1小时过期
});
```

