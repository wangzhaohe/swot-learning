@startuml Prototype Pattern

' !theme plain

interface Prototype {
  + {abstract} clone(): Prototype
}

class ConcretePrototype1 {
  - field1: String
  + ConcretePrototype1(prototype: ConcretePrototype1)
  + clone(): Prototype
  + getField1(): String
  + setField1(field1: String): void
}

class ConcretePrototype2 {
  - field2: int
  + ConcretePrototype2(prototype: ConcretePrototype2)
  + clone(): Prototype
  + getField2(): int
  + setField2(field2: int): void
}

class Client {
  - prototypeRegistry: Map&lt;String, Prototype&gt;
  + getPrototype(key: String): Prototype
  + addPrototype(key: String, prototype: Prototype): void
}

Prototype &lt;|.. ConcretePrototype1
Prototype &lt;|.. ConcretePrototype2
Client --&gt; Prototype : uses

note top of ConcretePrototype1
  // clone(): 实现深拷贝或浅拷贝
  return new ConcretePrototype1(this);
end note

@enduml
