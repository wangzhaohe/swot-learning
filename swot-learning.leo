<t tx="swot.20260313114540.245">**需求**：点击按钮，请求一个笑话，显示在页面上。

```html
&lt;button id="btn"&gt;来个笑话&lt;/button&gt;
&lt;div id="content"&gt;&lt;/div&gt;

&lt;script&gt;
    let btn = document.querySelector('#btn');
    let content = document.querySelector('#content');

    btn.onclick = function() {
        content.innerText = "正在加载中...";
        
        // 使用 fetch 请求
        fetch('https://api.apiopen.top/getJoke?page=1&amp;count=1&amp;type=text')
            .then(res =&gt; res.json())
            .then(data =&gt; {
                // 根据接口结构解析
                let joke = data.result[0].text;
                content.innerText = joke;
            })
            .catch(err =&gt; {
                content.innerText = "网络开了小差...";
            });
    };
&lt;/script&gt;
```

